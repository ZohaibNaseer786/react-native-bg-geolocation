# ─── Google Maps ──────────────────────────────────────────────────────────────
# Your Google Maps JavaScript API key (enable "Maps JavaScript API" in Google Cloud).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_js_api_key

# ─── Locations API (server-side, token never reaches the browser) ───────────────
# The endpoint that returns saved locations. Adjust to your real route.
LOCATIONS_API_URL=https://masjidpilot.duckdns.org/locations

